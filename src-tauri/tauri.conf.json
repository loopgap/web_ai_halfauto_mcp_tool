{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ai-workbench",
  "version": "0.4.1",
  "identifier": "com.ai-workbench.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AI Workbench",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "transparent": false,
        "additionalBrowserArgs": "--enable-features=WebRTCPipeWireCapturer,CanvasOopRasterization --force-gpu-rasterization --enable-zero-copy"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}