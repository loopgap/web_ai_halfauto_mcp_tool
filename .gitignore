# ══════════════════════════════════════════════════════════════════════════════
# AI Workbench .gitignore — 精确排除规则
# ══════════════════════════════════════════════════════════════════════════════

# ── Dependencies ────────────────────────────────────────────────────────────
node_modules/
.pnp/
.pnp.js
pnpm-lock.yaml
yarn.lock
package-lock.json
bun.lockb

# ── Build outputs ─────────────────────────────────────────────────────────────
dist/
dist-ssr/
src-tauri/target/
*.crate-bindings

# ── Logs ────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── OS files ─────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db
$RECYCLE.BIN/
*.lnk

# ── Editor files ─────────────────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.vscode/settings.*.json
!.vscode/tasks.json
!.vscode/launch.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo
*~
._*

# ── Environment / secrets ────────────────────────────────────────────────────
.env
.env.*.local
.env.local
.env.development
.env.production
!.env.example
*.local
*.pem
*.key
*.crt
credentials.json
secrets.json

# ── Generated / temp files ────────────────────────────────────────────────────
doctor-report.txt
error.txt
old_lockfile.txt
*.generated.md
generated/
*.tmp
*.bak
*.orig
*.rej
*.old
*.sage
*.lock.bak

# ── Test outputs ─────────────────────────────────────────────────────────────
test-results/
test-results.xml
playwright-report/
junit-report/
*.lcov
coverage/
.nyc_output/

# ── Tauri / Rust ─────────────────────────────────────────────────────────────
src-tauri/gen/schemas/
src-tauri/.cargo/
src-tauri/Cargo.lock

# ── Python (MCP skills) ─────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
.env
.venv
venv/
ENV/
env/
uv.lock

# ── Sisyphus orchestrator ────────────────────────────────────────────────────
.sisyphus/

# ── Misc ─────────────────────────────────────────────────────────────────────
*.tgz
.turbo/
.cache/
.parcel-cache/
.eslintcache
.stylelintcache
