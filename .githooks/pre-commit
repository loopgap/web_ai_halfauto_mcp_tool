#!/bin/sh
# ═══════════════════════════════════════════════════════════
# Git Pre-Commit Hook — 快速本地门禁
# ═══════════════════════════════════════════════════════════

echo "== [pre-commit] Running fast local gate =="

go run task.go check

if [ $? -ne 0 ]; then
  echo ""
  echo "== [pre-commit] BLOCKED: Fix failures above before committing =="
  echo "  Use: git commit --no-verify  to bypass (not recommended)"
  exit 1
fi

exit 0
