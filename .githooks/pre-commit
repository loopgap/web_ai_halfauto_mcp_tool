#!/bin/sh
# ============================================================
# AI Workbench - pre-commit hook
# Runs before every commit to ensure code quality.
#
# Checks:
#   1. TypeScript compilation (tsc --noEmit)
#   2. Governance contract tests
#   3. No debug/temp artifacts committed
# ============================================================

echo ""
echo "== [pre-commit] Running quality checks =="
echo ""

# -- PATH fix (Windows) --
export PATH="/c/Program Files/nodejs:$HOME/.cargo/bin:$APPDATA/npm:$PATH"

# -- 1. TypeScript check --
echo "[1/3] TypeScript..."
npx tsc --noEmit 2>&1
TS_EXIT=$?
if [ $TS_EXIT -ne 0 ]; then
    echo ""
    echo "[FAIL] TypeScript errors found. Fix them before committing."
    echo "  Run: npx tsc --noEmit"
    exit 1
fi
echo "[OK]  TypeScript: 0 errors"

# -- 2. Governance contract tests --
echo ""
echo "[2/3] Governance API contract tests..."
node scripts/test-governance-api-contract.mjs 2>&1
GOV_EXIT=$?
if [ $GOV_EXIT -ne 0 ]; then
    echo ""
    echo "[FAIL] Governance tests failed. Fix them before committing."
    echo "  Run: npm run test:governance:api"
    exit 1
fi
echo "[OK]  Governance tests passed"

# -- 3. Check for forbidden patterns --
echo ""
echo "[3/3] Checking for debug artifacts..."

FORBIDDEN_PATTERNS="console\.log\|debugger\|TODO.*HACK\|FIXME.*URGENT"
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(ts|tsx|js|jsx)$')

FOUND_ISSUES=0
if [ -n "$STAGED_FILES" ]; then
    for file in $STAGED_FILES; do
        # Check for debugger statements (but allow console.log in scripts/)
        if echo "$file" | grep -qv "^scripts/"; then
            DEBUGGER_LINES=$(git diff --cached -- "$file" | grep "^+" | grep -c "debugger" || true)
            if [ "$DEBUGGER_LINES" -gt 0 ]; then
                echo "[WARN] $file contains 'debugger' statement"
                FOUND_ISSUES=1
            fi
        fi
    done
fi

if [ $FOUND_ISSUES -eq 1 ]; then
    echo "[WARN] Found debug artifacts. Commit anyway? Use --no-verify to skip."
    # Warning only, don't block
fi
echo "[OK]  No blocking issues"

echo ""
echo "== [pre-commit] All checks passed =="
echo ""
exit 0
