#!/bin/sh
# ============================================================
# AI Workbench - pre-commit hook
# Runs the fast local CI gate before each commit.
# ============================================================

echo ""
echo "== [pre-commit] Running fast local gate =="
echo ""

# -- PATH fix (Windows Git Bash) --
export PATH="/c/Program Files/nodejs:$HOME/.cargo/bin:$APPDATA/npm:$PATH"

if ! command -v node >/dev/null 2>&1; then
    echo "[SKIP] node not found. CI will verify."
    exit 0
fi

node scripts/ci-local.mjs --fast --hook
STATUS=$?

if [ $STATUS -ne 0 ]; then
    echo ""
    echo "== [pre-commit] BLOCKED: Fix failures above before committing =="
    echo "  Use: git commit --no-verify  to bypass (not recommended)"
    exit $STATUS
fi

echo ""
echo "== [pre-commit] Fast gate passed =="
echo ""
exit 0
