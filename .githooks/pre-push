#!/bin/sh
# ═══════════════════════════════════════════════════════════
# Git Pre-Push Hook — 质量门禁闭环
# ═══════════════════════════════════════════════════════════

echo "🔍 [Gate] 启动推送前质量核验..."

# 执行统一任务引擎的 CI 检查
go run task.go ci

if [ $? -ne 0 ]; then
  echo "❌ [Gate] 质量检查未通过，推送已中止。请修复错误后再试。"
  exit 1
fi

echo "✅ [Gate] 质量核验通过，允许推送。"
exit 0
