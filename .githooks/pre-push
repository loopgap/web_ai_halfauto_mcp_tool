#!/bin/sh
# ============================================================
# Git Pre-Push Hook — 质量门禁闭环
# 全量模式: 运行完整 CI 检查
# ============================================================

echo "🔍 [pre-push] Starting quality gate..."

# 全量 CI 检查 (check + test)
if command -v go >/dev/null 2>&1; then
    go run task.go ci --full 2>&1
else
    # 无 Go 环境，直接运行底层命令
    echo "[pre-push] Go not found, running checks directly..."

    echo ">> TypeScript check"
    if ! pnpm exec tsc --noEmit 2>&1; then
        echo "❌ TypeScript check failed"
        exit 1
    fi

    echo ">> Rust clippy"
    if ! cargo clippy --jobs 4 -- -D warnings -A dead_code 2>&1; then
        echo "❌ Clippy failed"
        exit 1
    fi

    echo ""
    echo ">> Frontend tests"
    if ! pnpm vitest run --reporter=default 2>&1; then
        echo "❌ Frontend tests failed"
        exit 1
    fi

    echo ""
    echo ">> Backend tests"
    if ! cargo test --jobs 4 2>&1; then
        echo "❌ Backend tests failed"
        exit 1
    fi
fi

if [ $? -ne 0 ]; then
    echo ""
    echo "❌ [pre-push] BLOCKED: Quality gate failed"
    echo "  Please fix errors above before pushing"
    exit 1
fi

echo ""
echo "✅ [pre-push] Quality gate passed"
exit 0