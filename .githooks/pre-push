#!/bin/sh
# ============================================================
# Git Pre-Push Hook — 质量门禁闭环
# 全量模式: 运行完整 CI 检查
# ============================================================

echo "🔍 [pre-push] Starting quality gate..."

# 检查必要的工具
MISSING_TOOLS=""

if ! command -v go >/dev/null 2>&1; then
    MISSING_TOOLS="$MISSING_TOOLS go"
fi

if ! command -v pnpm >/dev/null 2>&1; then
    MISSING_TOOLS="$MISSING_TOOLS pnpm"
fi

if ! command -v cargo >/dev/null 2>&1; then
    MISSING_TOOLS="$MISSING_TOOLS cargo"
fi

# 如果缺少必要工具，跳过本地检查 (CI 会验证)
if [ -n "$MISSING_TOOLS" ]; then
    echo "⚠️  [pre-push] 本地工具缺失: $MISSING_TOOLS"
    echo "⚠️  [pre-push] 跳过本地检查，由远端 CI 验证"
    echo "✅ [pre-push] Quality gate passed (skipped - CI will validate)"
    exit 0
fi

# 全量 CI 检查 (check + test)
if command -v go >/dev/null 2>&1; then
    go run task.go ci --full 2>&1
    CI_RESULT=$?
else
    # 无 Go 环境，直接运行底层命令
    echo "[pre-push] Running checks directly..."

    echo ">> TypeScript check"
    if ! pnpm exec tsc --noEmit 2>&1; then
        echo "❌ TypeScript check failed"
        CI_RESULT=1
    fi

    echo ">> Rust clippy"
    if ! (cd src-tauri && cargo clippy --jobs 4 -- -D warnings -A dead_code) 2>&1; then
        echo "❌ Clippy failed"
        CI_RESULT=1
    fi

    echo ""
    echo ">> Frontend tests"
    if ! pnpm vitest run --reporter=default 2>&1; then
        echo "❌ Frontend tests failed"
        CI_RESULT=1
    fi

    echo ""
    echo ">> Backend tests"
    if ! (cd src-tauri && cargo test --jobs 4) 2>&1; then
        echo "❌ Backend tests failed"
        CI_RESULT=1
    fi
fi

if [ $CI_RESULT -ne 0 ]; then
    echo ""
    echo "❌ [pre-push] BLOCKED: Quality gate failed"
    echo "  Please fix errors above before pushing"
    exit 1
fi

echo ""
echo "✅ [pre-push] Quality gate passed"
exit 0
