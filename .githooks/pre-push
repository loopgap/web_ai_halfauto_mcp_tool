#!/bin/sh
# ============================================================
# AI Workbench - pre-push hook
# Runs the local CI gate before pushing to remote.
# ============================================================

echo ""
echo "== [pre-push] Running local CI gate =="
echo ""

export PATH="/c/Program Files/nodejs:$HOME/.cargo/bin:$APPDATA/npm:$PATH"

if ! command -v node >/dev/null 2>&1; then
    echo "[SKIP] node not found. CI will verify."
    exit 0
fi

node scripts/ci-local.mjs --hook
STATUS=$?

echo ""
if [ $STATUS -ne 0 ]; then
    echo "== [pre-push] BLOCKED: Fix failures above before pushing =="
    echo "  Use: git push --no-verify  to bypass (not recommended)"
    exit $STATUS
fi

echo "== [pre-push] Local CI passed. Pushing... =="
echo ""
exit 0
