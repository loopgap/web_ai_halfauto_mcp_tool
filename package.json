{
  "name": "ai-workbench",
  "private": true,
  "version": "0.3.0",
  "packageManager": "pnpm@10.11.0",
  "engines": {
    "node": ">=18"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "start": "node scripts/dev.mjs",
    "start:fe": "node scripts/dev.mjs --frontend",
    "start:build": "node scripts/dev.mjs --build",
    "bootstrap": "node scripts/bootstrap.mjs",
    "setup": "node scripts/bootstrap.mjs",
    "first-run": "node scripts/first-run.mjs",
    "hooks:install": "node scripts/install-hooks.mjs",
    "doctor": "node scripts/doctor.mjs",
    "doctor:report": "node scripts/doctor.mjs --report",
    "doctor:fix": "node scripts/doctor.mjs --fix",
    "build:app": "node scripts/build.mjs",
    "build:app:debug": "node scripts/build.mjs --debug",
    "build:app:clean": "node scripts/build.mjs --clean",
    "clean": "node scripts/clean.mjs soft",
    "clean:hard": "node scripts/clean.mjs hard",
    "clean:full": "node scripts/clean.mjs full",
    "check": "tsc --noEmit",
    "check:rust": "cargo check --manifest-path src-tauri/Cargo.toml",
    "check:all": "tsc --noEmit && cargo check --manifest-path src-tauri/Cargo.toml",
    "check:clippy": "cargo clippy --manifest-path src-tauri/Cargo.toml --jobs 1 -- -D warnings -A dead_code",
    "test:governance:api": "node scripts/test-governance-api-contract.mjs",
    "test:governance:rust": "cargo test governance_tests --manifest-path src-tauri/Cargo.toml -- --nocapture",
    "test:all": "pnpm test && tsc --noEmit && node scripts/test-governance-api-contract.mjs && cargo test --manifest-path src-tauri/Cargo.toml -- --nocapture",
    "env:check": "node scripts/check-environment.mjs",
    "env:fix": "node scripts/check-environment.mjs --fix",
    "governance:validate": "node scripts/validate-governance.mjs",
    "governance:evidence": "node scripts/build-evidence-pack.mjs --change governance/examples/change-record.example.json --quality governance/examples/quality-gate-result.example.json --release governance/examples/release-decision.example.json --output governance/examples/evidence-pack.generated.md",
    "ci:governance": "node scripts/check-environment.mjs && node scripts/validate-governance.mjs && node scripts/test-governance-api-contract.mjs",
    "ci:local": "node scripts/ci-local.mjs",
    "ci:local:fast": "node scripts/ci-local.mjs --fast",
    "ci:local:clean": "node scripts/ci-local.mjs --clean",
    "ci:linux": "node scripts/ci-linux.mjs",
    "release:preflight": "node scripts/release-preflight.mjs",
    "release:preflight:debug": "node scripts/release-preflight.mjs --debug",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ci": "vitest run --reporter=junit --outputFile=test-results.xml",
    "release:tag": "node scripts/release-tag.mjs",
    "git:ship": "node scripts/git-workflow.mjs"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-opener": "^2",
    "js-yaml": "^4.1.1",
    "lucide-react": "^0.575.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.13.1",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/js-yaml": "^4.0.9",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "@vitest/coverage-v8": "^3.2.1",
    "babel-plugin-transform-remove-console": "^6.9.4",
    "jsdom": "^26.1.0",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "vitest": "^3.2.1"
  }
}
