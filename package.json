{
  "name": "ai-workbench",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "start": "tauri dev",
    "start:fe": "vite",
    "setup": "pwsh -ExecutionPolicy Bypass -File scripts/setup.ps1",
    "doctor": "pwsh -ExecutionPolicy Bypass -File scripts/doctor.ps1",
    "doctor:fix": "pwsh -ExecutionPolicy Bypass -File scripts/doctor.ps1 -Fix",
    "doctor:report": "pwsh -ExecutionPolicy Bypass -File scripts/doctor.ps1 -Report",
    "check": "tsc --noEmit && cargo check --manifest-path src-tauri/Cargo.toml",
    "check:ts": "tsc --noEmit",
    "check:rust": "cargo check --manifest-path src-tauri/Cargo.toml",
    "clean": "rimraf node_modules/.cache dist src-tauri/target/debug/incremental",
    "clean:all": "rimraf node_modules dist src-tauri/target",
    "hooks:install": "pwsh -ExecutionPolicy Bypass -File scripts/install-hooks.ps1",
    "git:commit": "pwsh -ExecutionPolicy Bypass -File scripts/git-commit.ps1",
    "release": "pwsh -ExecutionPolicy Bypass -File scripts/release.ps1",
    "release:patch": "pwsh -ExecutionPolicy Bypass -File scripts/release.ps1 -Bump patch",
    "release:minor": "pwsh -ExecutionPolicy Bypass -File scripts/release.ps1 -Bump minor",
    "release:major": "pwsh -ExecutionPolicy Bypass -File scripts/release.ps1 -Bump major",
    "postinstall": "pwsh -ExecutionPolicy Bypass -File scripts/install-hooks.ps1",
    "env:check": "node scripts/check-environment.mjs",
    "governance:validate": "node scripts/validate-governance.mjs",
    "governance:evidence:example": "node scripts/build-evidence-pack.mjs --change governance/examples/change-record.example.json --quality governance/examples/quality-gate-result.example.json --release governance/examples/release-decision.example.json --output governance/examples/evidence-pack.generated.md",
    "test:governance:api": "node scripts/test-governance-api-contract.mjs",
    "test:governance:rust": "cargo test governance_tests --manifest-path src-tauri/Cargo.toml -- --nocapture",
    "test:all": "tsc --noEmit && node scripts/test-governance-api-contract.mjs && cargo test --manifest-path src-tauri/Cargo.toml -- --nocapture",
    "ci:governance": "node scripts/check-environment.mjs && node scripts/validate-governance.mjs && node scripts/test-governance-api-contract.mjs && node scripts/build-evidence-pack.mjs --change governance/examples/change-record.example.json --quality governance/examples/quality-gate-result.example.json --release governance/examples/release-decision.example.json --output governance/examples/evidence-pack.generated.md"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "js-yaml": "^4.1.1",
    "lucide-react": "^0.575.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.13.1",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/js-yaml": "^4.0.9",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "typescript": "~5.8.3",
    "vite": "^7.0.4"
  }
}
